# =============================================================================
# MARCUS LOCAL DEVELOPMENT ENVIRONMENT
# =============================================================================
# Copy this file to .env and fill in your values
# Never commit .env to version control (it's in .gitignore)
#
# See LOCAL_DEVELOPMENT.md for complete setup instructions
# =============================================================================

# -----------------------------------------------------------------------------
# AI Provider Configuration (Required - choose one)
# -----------------------------------------------------------------------------

# Anthropic (recommended)
# NOTE: do NOT name this ANTHROPIC_API_KEY — Claude Code reads that env var
# and would switch from your subscription to API billing. Marcus reads
# CLAUDE_API_KEY instead.
CLAUDE_API_KEY=sk-ant-api03-your-key-here

# OpenAI (alternative)
# OPENAI_API_KEY=sk-your-key-here

# -----------------------------------------------------------------------------
# Planka Kanban Backend (Required if using Planka)
# -----------------------------------------------------------------------------

# Local Planka connection (for Marcus connecting to Planka)
PLANKA_BASE_URL=http://localhost:3333
PLANKA_EMAIL=demo@demo.demo
PLANKA_PASSWORD=demo

# Planka Server Configuration (for Docker deployment)
PLANKA_PORT=3333
BASE_URL=http://localhost:3333
SECRET_KEY=secretkey

# Planka Admin User (created on first startup)
PLANKA_ADMIN_EMAIL=demo@demo.demo
PLANKA_ADMIN_PASSWORD=demo
PLANKA_ADMIN_NAME=Demo User
PLANKA_ADMIN_USERNAME=demo

# -----------------------------------------------------------------------------
# PostgreSQL Configuration (for Planka Docker deployment)
# -----------------------------------------------------------------------------

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=planka

# -----------------------------------------------------------------------------
# Alternative Kanban Providers (Optional)
# -----------------------------------------------------------------------------

# GitHub Projects (alternative to Planka)
# GITHUB_TOKEN=ghp_your-token-here
# GITHUB_OWNER=your-username
# GITHUB_REPO=your-repo

# Linear (alternative to Planka)
# LINEAR_API_KEY=lin_api_your-key-here
# LINEAR_TEAM_ID=your-team-id

# -----------------------------------------------------------------------------
# Marcus MCP Server Configuration
# -----------------------------------------------------------------------------

# Port for Marcus MCP server
MARCUS_MCP_PORT=4298

# Configuration file selection
# Options: config_marcus.json (default), config_marcus.json.anthropic, config_marcus.json.github, etc.
# MARCUS_CONFIG=config_marcus.json.anthropic

# Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Optional: Advanced Configuration
# -----------------------------------------------------------------------------

# Enable specific features
# MARCUS_ENABLE_SUBTASKS=true

# Monitoring
# MARCUS_MONITORING_INTERVAL=60

# Slack notifications
# MARCUS_SLACK_ENABLED=false
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email notifications
# MARCUS_EMAIL_ENABLED=false
