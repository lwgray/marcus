# Database Configuration  # pragma: allowlist secret
DATABASE_URL=postgresql://user:password@localhost:5432/taskmanagement  # pragma: allowlist secret
DATABASE_POOL_SIZE=10

# Security Configuration
SECRET_KEY=change-this-to-a-strong-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# API Configuration
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Application Configuration
DEBUG=False
LOG_LEVEL=INFO
