graph TD
    User(["User / Contributor"])

    subgraph ENTRY["Entry Points"]
        direction LR
        POS["Posidonius\nlocalhost:8000"]
        SKILL["/marcus Skill\nClaude Code"]
        DMCP["Direct MCP\nany agent"]
    end

    RUN["run_experiment.py"]

    subgraph TMUX["tmux Session"]
        direction LR
        CR["Creator\ncreate_project"]
        WK["Workers 1..N\nwork loop"]
        MN["Monitor\nend_experiment"]
    end

    subgraph MARCUS["Marcus MCP Server · localhost:4298"]
